<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.realgram.HelloController"
            stylesheets="@style.css"
            styleClass="root">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
    </padding>

    <top>
        <VBox spacing="10">
            <padding><Insets bottom="15"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="IP:" styleClass="label"/>
                <TextField fx:id="ipField" text="" prefWidth="110"/>
                <Label text="Port:" styleClass="label"/>
                <TextField fx:id="portField" text="" prefWidth="70"/>
                <Button fx:id="connectButton" text="Connect" onAction="#onConnectButtonClick" minWidth="90"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" text="Disconnected" style="-fx-text-fill: #f44336; -fx-font-weight: bold;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Username:" styleClass="label"/>
                <TextField fx:id="usernameField" text="" prefWidth="150" promptText="Ваше ім'я..."/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TextArea fx:id="logArea" editable="false" wrapText="true"
                  promptText="Повідомлення з'являться тут..."
                  VBox.vgrow="ALWAYS"/>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER">
            <padding><Insets top="15"/></padding>
            <TextField fx:id="messageField" HBox.hgrow="ALWAYS"
                       promptText="Напишіть повідомлення та натисніть Enter..."
                       prefHeight="35" onKeyPressed="#onKeyPressed"/>
            <Button fx:id="sendButton" text="Send" onAction="#onSendButtonClick"
                    prefHeight="35" prefWidth="80"/>
        </HBox>
    </bottom>
</BorderPane>